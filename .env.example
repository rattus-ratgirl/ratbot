# Discord bot token
DISCORD__TOKEN=your_token_here

# General database information - the bot will use this to create a connection string to any MySQL instance
DB__HOST=localhost
DB__PORT=3306
DB__DATABASE=dbname
DB__USER=username
DB__PASSWORD=userpass

# Optional: send structured logs to Grafana Cloud Logs / Loki
# Example URI: https://logs-prod-012.grafana.net/loki/api/v1/push
GRAFANA__LOGS__URI=
GRAFANA__LOGS__USERNAME=
GRAFANA__LOGS__PASSWORD=
GRAFANA__LOGS__ENVIRONMENT=production
